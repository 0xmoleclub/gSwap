# RPC Endpoint for Polkadot Hub EVM
# NOTE: rpc.polkadot-hub.io does not resolve. Use the correct endpoint when available.
# For Westend testnet: https://westend-asset-hub-eth-rpc.polkadot.io
RPC_ENDPOINT=https://services.polkadothub-rpc.com/testnet

# Archive URL (Subsquid archive for Polkadot Hub)
# NOTE: No EVM archive exists yet for Polkadot Hub. Processor runs in RPC-only mode.
ARCHIVE_URL=https://v2.archive.subsquid.io/network/polkadot-hub-evm

# Database
DB_NAME=gswap
DB_PORT=5432
DB_HOST=localhost
DB_USER=postgres
DB_PASS=postgres

# Block range - Factory deployed at block 5006149
START_BLOCK=5006149

# Agent Configuration
DEPLOY_BLOCK=5006149

# Deployed Contract Addresses
FACTORY_ADDRESS=0x90959f9bf93ebe320d8af0304fd6ae87f0c7fd7c

# Client GraphQL endpoint (indexer Apollo Server)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000

# ============================================
# ARBITRAGE AGENT CONFIGURATION
# ============================================

# Private key for the arbitrage agent wallet (required for real execution)
# WARNING: Keep this secret! The agent will use this wallet to execute trades.
# Format: 0x... (64 hex characters)
PRIVATE_KEY=

# Chain ID for Polkadot Hub EVM
CHAIN_ID=420420417

# Maximum gas price in wei (default: 500 gwei)
# Transactions will not be submitted if gas price exceeds this value
MAX_GAS_PRICE=500000000000

# OpenRouter API Key for LLM analysis (optional)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter Model (free tier options)
# Default: qwen/qwen3-coder:free
# Other options: arcee-ai/trinity-large-preview:free, google/gemini-2.5-pro-exp-03-25:free
OPENROUTER_MODEL=qwen/qwen3-coder:free

# GraphQL endpoint for the agent
GRAPHQL_ENDPOINT=http://localhost:4000/graphql
